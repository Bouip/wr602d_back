<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VROUM VROUM — Admin</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@400;700;900&display=swap');

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: #0d0d0d;
            color: #fff;
            font-family: 'Barlow Condensed', sans-serif;
            min-height: 100vh;
            display: flex;
        }

        .sidebar {
            width: 220px;
            background: #111;
            border-right: 3px solid #FFD700;
            padding: 30px 20px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            min-height: 100vh;
        }

        .sidebar-logo {
            font-family: 'Bebas Neue', cursive;
            font-size: 32px;
            color: #FFD700;
            letter-spacing: 4px;
            margin-bottom: 30px;
            transform: skewX(-4deg);
            display: block;
        }

        .sidebar-label {
            font-size: 10px;
            letter-spacing: 3px;
            color: rgba(255,255,255,0.25);
            margin-bottom: 8px;
            margin-top: 16px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            color: rgba(255,255,255,0.5);
            text-decoration: none;
            font-weight: 700;
            font-size: 14px;
            letter-spacing: 2px;
            border-radius: 2px;
            transition: all 0.15s;
            border: 2px solid transparent;
        }

        .nav-link:hover, .nav-link.active {
            background: rgba(255,215,0,0.1);
            border-color: #FFD700;
            color: #FFD700;
        }

        .main {
            flex: 1;
            padding: 40px;
            overflow-y: auto;
        }

        .page-title {
            font-family: 'Bebas Neue', cursive;
            font-size: 52px;
            color: #fff;
            letter-spacing: 5px;
            margin-bottom: 30px;
            transform: skewX(-3deg);
            display: inline-block;
            border-left: 5px solid #FFD700;
            padding-left: 16px;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
            margin-bottom: 40px;
        }

        .stat-card {
            background: #1a1a1a;
            border: 2px solid #333;
            border-radius: 2px;
            padding: 24px;
            transition: border-color 0.15s;
        }

        .stat-card:hover { border-color: #FFD700; }

        .stat-label {
            font-size: 11px;
            letter-spacing: 3px;
            color: rgba(255,255,255,0.3);
            margin-bottom: 8px;
        }

        .stat-value {
            font-family: 'Bebas Neue', cursive;
            font-size: 48px;
            color: #FFD700;
            letter-spacing: 3px;
            line-height: 1;
        }

        .section-title {
            font-family: 'Bebas Neue', cursive;
            font-size: 28px;
            letter-spacing: 4px;
            color: rgba(255,255,255,0.6);
            margin-bottom: 16px;
            margin-top: 32px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead tr {
            background: #1a1a1a;
            border-bottom: 2px solid #FFD700;
        }

        th {
            padding: 12px 16px;
            text-align: left;
            font-size: 11px;
            letter-spacing: 3px;
            color: rgba(255,255,255,0.4);
            font-weight: 900;
        }

        td {
            padding: 12px 16px;
            font-size: 15px;
            font-weight: 700;
            border-bottom: 1px solid #222;
        }

        tr:hover td { background: rgba(255,215,0,0.04); }

        .badge {
            display: inline-block;
            padding: 3px 10px;
            font-size: 11px;
            letter-spacing: 2px;
            font-weight: 900;
            border-radius: 2px;
        }

        .badge-admin {
            background: rgba(255,215,0,0.15);
            color: #FFD700;
            border: 1px solid #FFD700;
        }

        .badge-user {
            background: rgba(255,255,255,0.05);
            color: rgba(255,255,255,0.4);
            border: 1px solid #333;
        }

        .gold { color: #FFD700; }
        .green { color: #00ff88; }
        .red { color: #ff4444; }
    </style>
</head>
<body>
    <nav class="sidebar">
        <span class="sidebar-logo">🚕 VROUM</span>
        <span class="sidebar-label">NAVIGATION</span>
        <a href="{{ path('app_admin') }}" class="nav-link {{ app.request.attributes.get('_route') == 'app_admin' ? 'active' : '' }}">
            📊 DASHBOARD
        </a>
        <a href="{{ path('app_admin_users') }}" class="nav-link {{ app.request.attributes.get('_route') == 'app_admin_users' ? 'active' : '' }}">
            👥 JOUEURS
        </a>
        <a href="{{ path('app_admin_scores') }}" class="nav-link {{ app.request.attributes.get('_route') == 'app_admin_scores' ? 'active' : '' }}">
            🏆 SCORES
        </a>
        <span class="sidebar-label">COMPTE</span>
        <a href="{{ path('app_logout') }}" class="nav-link red">⏏ DÉCONNEXION</a>
    </nav>
    <main class="main">
        {% block content %}{% endblock %}
    </main>
</body>
</html>