<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VROUM VROUM — Admin</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap');

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: #f0f2f5;
            color: #1a1a2e;
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
        }

        /* ── SIDEBAR ── */
        .sidebar {
            width: 260px;
            background: #1a1a2e;
            padding: 0;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            position: sticky;
            top: 0;
            height: 100vh;
            overflow-y: auto;
            box-shadow: 4px 0 24px rgba(0,0,0,0.15);
        }

        .sidebar-brand {
            padding: 32px 24px 28px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            position: relative;
            overflow: hidden;
        }

        .sidebar-brand::before {
            content: '';
            position: absolute;
            top: -60px; right: -60px;
            width: 160px; height: 160px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,77,141,0.15), transparent 70%);
            pointer-events: none;
        }

        .sidebar-eyebrow {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: #FF4D8D;
            display: block;
            margin-bottom: 8px;
        }

        .sidebar-logo {
            font-family: 'Bebas Neue', cursive;
            font-size: 44px;
            color: #fff;
            letter-spacing: 5px;
            line-height: 0.88;
            display: block;
            text-shadow: 0 0 40px rgba(255,77,141,0.3);
        }

        .sidebar-logo-outline {
            font-family: 'Bebas Neue', cursive;
            font-size: 44px;
            color: transparent;
            -webkit-text-stroke: 1.5px rgba(255,255,255,0.15);
            letter-spacing: 5px;
            line-height: 0.88;
            display: block;
        }

        .sidebar-nav {
            padding: 20px 14px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .sidebar-section {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.18);
            margin: 20px 8px 8px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 14px;
            color: rgba(255,255,255,0.4);
            text-decoration: none;
            font-weight: 600;
            font-size: 13px;
            letter-spacing: 0.3px;
            border-radius: 10px;
            transition: all 0.15s;
            border: 1px solid transparent;
            margin-bottom: 2px;
            position: relative;
        }

        .nav-link svg {
            width: 16px; height: 16px;
            fill: currentColor;
            flex-shrink: 0;
            opacity: 0.7;
        }

        .nav-link:hover {
            background: rgba(255,255,255,0.05);
            color: rgba(255,255,255,0.8);
        }

        .nav-link.active {
            background: rgba(255,77,141,0.12);
            border-color: rgba(255,77,141,0.2);
            color: #FF4D8D;
        }

        .nav-link.active svg { opacity: 1; }

        .nav-link.active::before {
            content: '';
            position: absolute;
            left: 0; top: 20%; bottom: 20%;
            width: 3px;
            background: #FF4D8D;
            border-radius: 0 2px 2px 0;
        }

        .nav-link.danger { color: rgba(239,68,68,0.4); }
        .nav-link.danger:hover { background: rgba(239,68,68,0.08); color: #ef4444; border-color: rgba(239,68,68,0.15); }

        .sidebar-footer {
            margin-top: auto;
            padding: 16px 14px 24px;
            border-top: 1px solid rgba(255,255,255,0.05);
        }

        /* ── TOPBAR ── */
        .main {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            overflow: hidden;
        }

        .topbar {
            background: #fff;
            border-bottom: 1px solid #e8e8e8;
            padding: 0 48px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 50;
            box-shadow: 0 1px 8px rgba(0,0,0,0.06);
        }

        .topbar-breadcrumb {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: #bbb;
            font-weight: 500;
        }

        .topbar-breadcrumb span { color: #1a1a2e; font-weight: 700; }

        .topbar-breadcrumb svg {
            width: 14px; height: 14px;
            fill: #ddd;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .topbar-badge {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            background: rgba(255,77,141,0.08);
            border: 1px solid rgba(255,77,141,0.2);
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
            color: #FF4D8D;
            letter-spacing: 0.5px;
        }

        .topbar-dot {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: #FF4D8D;
            box-shadow: 0 0 6px rgba(255,77,141,0.8);
        }

        /* ── CONTENT ── */
        .content {
            flex: 1;
            padding: 40px 48px;
            overflow-y: auto;
        }

        /* ── PAGE HEADER ── */
        .page-header {
            margin-bottom: 36px;
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
        }

        .page-header-left {}

        .page-eyebrow {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: #FF4D8D;
            display: block;
            margin-bottom: 4px;
        }

        .page-title {
            font-family: 'Bebas Neue', cursive;
            font-size: 52px;
            color: #1a1a2e;
            letter-spacing: 4px;
            line-height: 1;
        }

        /* ── STAT CARDS ── */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
            margin-bottom: 40px;
        }

        .stat-card {
            background: #fff;
            border: 1.5px solid #e8e8e8;
            border-radius: 16px;
            padding: 28px 24px;
            transition: all 0.2s;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: linear-gradient(90deg, #FF4D8D, rgba(255,77,141,0));
            opacity: 0;
            transition: opacity 0.2s;
        }

        .stat-card:hover {
            border-color: rgba(255,77,141,0.2);
            box-shadow: 0 8px 24px rgba(255,77,141,0.08);
            transform: translateY(-2px);
        }

        .stat-card:hover::before { opacity: 1; }

        .stat-icon {
            width: 36px; height: 36px;
            border-radius: 10px;
            background: rgba(255,77,141,0.08);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 16px;
        }

        .stat-icon svg {
            width: 18px; height: 18px;
            fill: #FF4D8D;
        }

        .stat-label {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #bbb;
            margin-bottom: 8px;
            display: block;
        }

        .stat-value {
            font-family: 'Bebas Neue', cursive;
            font-size: 52px;
            color: #1a1a2e;
            letter-spacing: 2px;
            line-height: 1;
        }

        .stat-value.pink { color: #FF4D8D; }

        /* ── SECTION ── */
        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
            margin-top: 40px;
        }

        .section-title {
            font-family: 'Bebas Neue', cursive;
            font-size: 26px;
            letter-spacing: 3px;
            color: #1a1a2e;
        }

        /* ── TABLE ── */
        .table-wrap {
            background: #fff;
            border: 1.5px solid #e8e8e8;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        }

        table { width: 100%; border-collapse: collapse; }

        thead tr {
            background: #fafafa;
            border-bottom: 1.5px solid #e8e8e8;
        }

        th {
            padding: 14px 20px;
            text-align: left;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #bbb;
        }

        td {
            padding: 14px 20px;
            font-size: 14px;
            font-weight: 500;
            color: #444;
            border-bottom: 1px solid #f5f5f5;
        }

        tr:last-child td { border-bottom: none; }

        tbody tr { transition: background 0.1s; }
        tbody tr:hover td { background: #fafafa; }

        /* ── BADGES ── */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 10px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.5px;
            border-radius: 20px;
        }

        .badge-dot {
            width: 5px; height: 5px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .badge-admin {
            background: rgba(255,77,141,0.08);
            color: #FF4D8D;
            border: 1px solid rgba(255,77,141,0.2);
        }

        .badge-admin .badge-dot { background: #FF4D8D; }

        .badge-user {
            background: #f5f5f5;
            color: #aaa;
            border: 1px solid #e8e8e8;
        }

        .badge-user .badge-dot { background: #ccc; }

        .text-pink { color: #FF4D8D; font-weight: 700; }
        .text-muted { color: #bbb; font-size: 13px; }
        .text-bold { font-weight: 700; color: #1a1a2e; }
    </style>
</head>
<body>
    <nav class="sidebar">
        <div class="sidebar-brand">
            <span class="sidebar-eyebrow">Backoffice</span>
            <span class="sidebar-logo">VROUM</span>
            <span class="sidebar-logo-outline">VROUM</span>
        </div>

        <div class="sidebar-nav">
            <span class="sidebar-section">Navigation</span>

            <a href="{{ path('app_admin') }}" class="nav-link {{ app.request.attributes.get('_route') == 'app_admin' ? 'active' : '' }}">
                <svg viewBox="0 0 24 24"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>
                Dashboard
            </a>
            <a href="{{ path('app_admin_users') }}" class="nav-link {{ app.request.attributes.get('_route') == 'app_admin_users' ? 'active' : '' }}">
                <svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
                Joueurs
            </a>
            <a href="{{ path('app_admin_scores') }}" class="nav-link {{ app.request.attributes.get('_route') == 'app_admin_scores' ? 'active' : '' }}">
                <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14l-5-5 1.41-1.41L12 14.17l7.59-7.59L21 8l-9 9z"/></svg>
                Scores
            </a>

            <div class="sidebar-footer">
                <span class="sidebar-section">Compte</span>
                <a href="{{ path('app_logout') }}" class="nav-link danger">
                    <svg viewBox="0 0 24 24"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5-5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg>
                    Déconnexion
                </a>
            </div>
        </div>
    </nav>

    <div class="main">
        <div class="topbar">
            <div class="topbar-breadcrumb">
                Vroum Vroum
                <svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6-6-6z"/></svg>
                <span>{% block page_name %}Admin{% endblock %}</span>
            </div>
            <div class="topbar-right">
                <div class="topbar-badge">
                    <div class="topbar-dot"></div>
                    Admin
                </div>
            </div>
        </div>

        <main class="content">
            {% block content %}{% endblock %}
        </main>
    </div>
</body>
</html>